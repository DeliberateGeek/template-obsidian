# Ignore volatile UI-related state (machine-specific)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/workspace.json.bak
.obsidian/hotkeys.json

# Ignore cache and temporary files
.obsidian/cache/
.obsidian/drafts/
.obsidian/plugins/*/cache*
.obsidian/snippets/*/cache*

# Plugin files are tracked in git for cross-device sync
# (Disable auto-updates in Obsidian to prevent version drift)

# Ignore sync and history
.obsidian/sync-config.json
.obsidian/.DS_Store

# Ignore system files and trash
.DS_Store
Thumbs.db
.trash/
*.tmp

# Ignore OS-specific files
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# Ignore Claude Code temporary files
.claude/temp/
.claude/settings.local.json
.claude/settings.json.backup*
critique-prompt-*.txt
